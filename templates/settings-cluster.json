{
  "_comment_overview": [
    "Claude Code settings for Yale YCRC HPC clusters (Bouchet, McCleary, Milgram).",
    "Adapted from the local macOS template. Uses blanket Bash(*) with safety",
    "hooks, glob-based deny rules for Linux, and extra protections for shared",
    "filesystems. No telemetry traffic from cluster nodes.",
    "",
    "After copying to ~/.claude/settings.json, run /security-setup to",
    "personalize protections for your machine."
  ],
  "_comment_cluster_info": [
    "=== YCRC Cluster Quick Reference ===",
    "",
    "SSH access:        ssh <netid>@<cluster>.ycrc.yale.edu",
    "Docs:              https://docs.ycrc.yale.edu/clusters/",
    "Help:              hpc@yale.edu",
    "",
    "=== Storage (varies by cluster — check docs) ===",
    "",
    "Home:     ~/                                  Limited quota, backed up",
    "Project:  ~/project_pi_<PI netid>/            Shared per group, backed up",
    "Scratch:  ~/scratch_pi_<PI netid>/            Shared, NO backup, PURGED after 60 days",
    "",
    "Check quotas:      getquota",
    "List your paths:   mydirectories",
    "",
    "=== Conda ===",
    "",
    "module load miniconda",
    "conda activate <env>",
    "",
    "=== SLURM Quick Reference ===",
    "",
    "Submit batch job:     sbatch my_job.sh",
    "Interactive job:      salloc -p devel -t 2:00:00 --mem=8G",
    "List your jobs:       squeue --me",
    "Cancel a job:         scancel <jobid>",
    "Job details:          sacct -j <jobid>",
    "",
    "=== Common Partitions (check your cluster's docs for specifics) ===",
    "",
    "devel:      short interactive/test jobs",
    "day:        up to 24h, general purpose",
    "week:       up to 7 days",
    "gpu:        GPU nodes (varies by cluster)",
    "gpu_devel:  GPU testing, limited allocation",
    "",
    "Default walltime: 1 hour on ALL partitions.",
    "",
    "=== Batch Script Template ===",
    "",
    "#!/bin/bash",
    "#SBATCH --job-name=my_job",
    "#SBATCH --partition=day",
    "#SBATCH --time=4:00:00",
    "#SBATCH --cpus-per-task=4",
    "#SBATCH --mem-per-cpu=5G",
    "#SBATCH --mail-type=ALL",
    "#SBATCH --mail-user=<your email>",
    "#SBATCH --output=slurm-%j.out",
    "",
    "module purge",
    "module load miniconda",
    "conda activate <env>",
    "<your_command>"
  ],
  "env": {
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch",
      "Bash(*)",
      "WebFetch(domain:www.ncbi.nlm.nih.gov)",
      "WebFetch(domain:pmc.ncbi.nlm.nih.gov)",
      "WebFetch(domain:pubmed.ncbi.nlm.nih.gov)",
      "WebFetch(domain:www.ensembl.org)",
      "WebFetch(domain:rest.ensembl.org)",
      "WebFetch(domain:useast.ensembl.org)",
      "WebFetch(domain:metazoa.ensembl.org)",
      "WebFetch(domain:www.orthodb.org)",
      "WebFetch(domain:data.orthodb.org)",
      "WebFetch(domain:flybase.org)",
      "WebFetch(domain:www.alliancegenome.org)",
      "WebFetch(domain:www.bgee.org)",
      "WebFetch(domain:www.nature.com)",
      "WebFetch(domain:www.proteinatlas.org)",
      "WebFetch(domain:www.genecards.org)",
      "WebFetch(domain:www.wormbase.org)",
      "WebFetch(domain:www.uniprot.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:bioconductor.org)",
      "WebFetch(domain:www.ebi.ac.uk)",
      "WebFetch(domain:satijalab.org)",
      "WebFetch(domain:www.sc-best-practices.org)",
      "WebFetch(domain:iqtree.github.io)",
      "WebFetch(domain:etetoolkit.github.io)",
      "WebFetch(domain:www.biostars.org)",
      "WebFetch(domain:docs.ycrc.yale.edu)",
      "mcp__claude_ai_bioRxiv__*",
      "mcp__claude_ai_Scholar_Gateway__*",
      "mcp__claude_ai_PubMed__search_articles"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.ssh/**)",
      "Read(**/.netrc)",
      "Read(**/.bash_history)",
      "Read(**/.python_history)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",
      "Read(**/*token*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.aws/**)",
      "Read(**/.config/gcloud/**)",
      "Read(**/.kube/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/.ssh/**)",
      "Edit(**/.netrc)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*credentials*)",
      "Edit(**/*secret*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/.ssh/**)",
      "Write(**/.netrc)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*credentials*)",
      "Write(**/*secret*)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(gh repo delete *)",
      "Bash(gh api -X DELETE *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /nfs*)",
      "Bash(rm -rf ~*)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(mkfs *)",
      "Bash(dd if=*)",
      "Bash(crontab *)",
      "Bash(nohup *)",
      "Bash(ssh *)",
      "Bash(ssh)",
      "Bash(nc *)",
      "Bash(netcat *)",
      "Bash(nmap *)",
      "Bash(telnet *)",
      "Bash(kill -9 *)",
      "Bash(killall *)",
      "Bash(pkill *)"
    ],
    "additionalDirectories": [
      "~/.claude",
      "/path/to/your/project"
    ]
  }
}
